
# Select the WhatsApp transport provider: meta | evolution
WHATSAPP_PROVIDER="evolution"

# Evolution API settings
EVOLUTION_API_URL="http://<your-evolution-host>:3333"
EVOLUTION_API_KEY="<your key>"
EVOLUTION_INSTANCE_NAME="<your instance>"
EVOLUTION_WEBHOOK_SECRET=""
EVOLUTION_WEBHOOK_SECRET_HEADER="apikey"

# Meta Cloud API settings
# This token expires after 24 hours. You can get a new one from the your Meta App Dashboard > API Setup
# Or you can create an access token at the System User level from the Meta Business Settings: https://business.facebook.com/settings/system-users

ACCESS_TOKEN=""

APP_ID=""
APP_SECRET=""
RECIPIENT_WAID="" # Optional fallback target, digits only
VERSION="v18.0"
PHONE_NUMBER_ID=""

VERIFY_TOKEN=""

OPENAI_API_KEY="sk-..."
OPENAI_ASSISTANT_ID=""

# Google AI / Gemini API
GOOGLE_AI_API_KEY=""

# Reliability tuning
OPENAI_RUN_TIMEOUT_SECONDS="30"
OPENAI_POLL_INTERVAL_SECONDS="0.5"
OPENAI_MAX_RETRIES="2"
OPENAI_RETRY_BACKOFF_SECONDS="0.5"
OUTBOUND_CHANNEL="whatsapp" # whatsapp | telegram | instagram | messenger | tiktok

# Optional non-WhatsApp outbound channels. These adapters send a normalized
# payload to your bridge/direct API endpoint and stay disabled if the URL or
# default recipient ID is not configured.
TELEGRAM_BOT_TOKEN=""
TELEGRAM_DEFAULT_CHAT_ID=""
TELEGRAM_SEND_TIMEOUT_SECONDS="10"

INSTAGRAM_OUTBOUND_URL="https://your-instagram-bridge.example.com/messages"
INSTAGRAM_ACCESS_TOKEN=""
INSTAGRAM_DEFAULT_RECIPIENT_ID=""
INSTAGRAM_SEND_TIMEOUT_SECONDS="10"
INSTAGRAM_CONNECT_URL=""

MESSENGER_OUTBOUND_URL="https://your-messenger-bridge.example.com/messages"
MESSENGER_PAGE_ACCESS_TOKEN=""
MESSENGER_DEFAULT_RECIPIENT_ID=""
MESSENGER_SEND_TIMEOUT_SECONDS="10"
MESSENGER_CONNECT_URL=""

# TikTok currently ships as outbound-only bridge support in this repo.
# Keep using a relay/direct outbound endpoint here until you have a verified
# inbound webhook contract and API scope to implement.
TIKTOK_OUTBOUND_URL="https://your-tiktok-bridge.example.com/messages"
TIKTOK_ACCESS_TOKEN=""
TIKTOK_DEFAULT_RECIPIENT_ID=""
TIKTOK_SEND_TIMEOUT_SECONDS="10"
TIKTOK_CONNECT_URL=""

# CRM Lite export (optional). Sends normalized analytics events to your CRM
# intake webhook (HubSpot workflow webhook, Zapier Catch Hook, custom endpoint).
CRM_EXPORT_ENABLED="false"
CRM_EXPORT_WEBHOOK_URL=""
CRM_EXPORT_API_KEY=""
CRM_EXPORT_TIMEOUT_SECONDS="5"

IDEMPOTENCY_WINDOW_SECONDS="300"
SIGNATURE_MAX_SKEW_SECONDS="300"
SIGNATURE_REPLAY_WINDOW_SECONDS="300"

# State store backend rollout
STATE_STORE_BACKEND="memory" # memory | sqlite
STATE_STORE_SQLITE_PATH="data/runtime_state.db"
STATE_STORE_FALLBACK_TO_MEMORY="true"

# Flask session secret — MUST be set in production to a long random string.
# If not set, a new random key is generated on every restart (all sessions lost).
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY="<generate one>"

# SaaS database (PostgreSQL in production, omit for no-DB mode)
DATABASE_URL=""

# Password reset email (SMTP). Leave SMTP_HOST blank to disable email dispatch.
APP_BASE_URL="https://<your-railway-domain>"
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USERNAME=""
SMTP_PASSWORD=""
SMTP_FROM_ADDRESS="noreply@yourdomain.com"
SMTP_USE_TLS="true"
PASSWORD_RESET_TOKEN_TTL_MINUTES="30"

# Paddle billing (sandbox) — obtain keys from https://sandbox-vendors.paddle.com
PADDLE_API_KEY="<from sandbox-vendors.paddle.com>"
PADDLE_CLIENT_TOKEN="<from sandbox-vendors.paddle.com>"
PADDLE_WEBHOOK_SECRET="<from paddle notifications>"
PADDLE_STARTER_PRICE_ID="pri_..."
PADDLE_PRO_PRICE_ID="pri_..."
PADDLE_BUSINESS_PRICE_ID="pri_..."
