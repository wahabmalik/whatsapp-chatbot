
# Select the WhatsApp transport provider: meta | evolution
WHATSAPP_PROVIDER="evolution"

# Evolution API settings
EVOLUTION_API_URL=""
EVOLUTION_API_KEY=""
EVOLUTION_INSTANCE_NAME=""
EVOLUTION_WEBHOOK_SECRET=""
EVOLUTION_WEBHOOK_SECRET_HEADER="apikey"

# Meta Cloud API settings
# This token expires after 24 hours. You can get a new one from the your Meta App Dashboard > API Setup
# Or you can create an access token at the System User level from the Meta Business Settings: https://business.facebook.com/settings/system-users

ACCESS_TOKEN=""

APP_ID=""
APP_SECRET=""
RECIPIENT_WAID="" # Optional fallback target, digits only
VERSION="v18.0"
PHONE_NUMBER_ID=""

VERIFY_TOKEN=""

OPENAI_API_KEY=""
OPENAI_ASSISTANT_ID=""

# Google AI / Gemini API
GOOGLE_AI_API_KEY=""

# Reliability tuning
OPENAI_RUN_TIMEOUT_SECONDS="30"
OPENAI_POLL_INTERVAL_SECONDS="0.5"
OPENAI_MAX_RETRIES="2"
OPENAI_RETRY_BACKOFF_SECONDS="0.5"
IDEMPOTENCY_WINDOW_SECONDS="300"
SIGNATURE_MAX_SKEW_SECONDS="300"
SIGNATURE_REPLAY_WINDOW_SECONDS="300"

# State store backend rollout
STATE_STORE_BACKEND="memory" # memory | sqlite
STATE_STORE_SQLITE_PATH="data/runtime_state.db"
STATE_STORE_FALLBACK_TO_MEMORY="true"

# Flask session secret — MUST be set in production to a long random string.
# If not set, a new random key is generated on every restart (all sessions lost).
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=""

# SaaS database (PostgreSQL in production, omit for no-DB mode)
DATABASE_URL=""

# Password reset email (SMTP). Leave SMTP_HOST blank to disable email dispatch.
APP_BASE_URL="https://yourdomain.com"
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USERNAME=""
SMTP_PASSWORD=""
SMTP_FROM_ADDRESS="noreply@yourdomain.com"
SMTP_USE_TLS="true"
PASSWORD_RESET_TOKEN_TTL_MINUTES="30"

# Stripe billing — obtain keys from https://dashboard.stripe.com/apikeys
# STRIPE_SECRET_KEY     — sk_live_... (or sk_test_... for test mode)
# STRIPE_PUBLISHABLE_KEY — pk_live_... (used in frontend JS if needed)
# Price IDs come from Stripe Dashboard > Products. Create one recurring price
# per plan and paste the price ID (price_...) below.
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
STRIPE_STARTER_PRICE_ID=""
STRIPE_PRO_PRICE_ID=""
STRIPE_BUSINESS_PRICE_ID=""
